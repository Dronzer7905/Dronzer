# Dronzer Gateway - Backend Environment Variables
# Copy this file to .env and fill in your details

# Database Configuration (PostgreSQL)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://dronzer:your_secure_password@localhost:5433/dronzer_prod

# Application Settings
ENVIRONMENT=production
LOG_LEVEL=INFO

# Security (JWT / Encryption)
# Run `openssl rand -hex 32` to generate secure keys
SECRET_KEY=your_secret_key_here
ENCRYPTION_KEY=your_32_byte_encryption_key_here

# Telemetry / Observability
ENABLE_METRICS=true
